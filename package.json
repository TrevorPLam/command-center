{
  "name": "command-center",
  "version": "0.1.0",
  "description": "Local AI Command Center - A panel-driven control surface for local AI operations",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "preflight": "tsx scripts/preflight.ts",
    "check-runtime": "tsx scripts/check-runtime.ts",
    "worker": "tsx scripts/run-worker.ts",
    "worker:dev": "tsx scripts/run-worker.ts --verbose",
    "worker:multi": "tsx scripts/run-worker.ts --workers 3 --verbose",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx scripts/db/seed.ts",
    "db:reset": "tsx scripts/db/reset.ts",
    "eval:quick": "tsx scripts/eval/run-promptfoo.ts --mode quick",
    "eval:full": "tsx scripts/eval/run-promptfoo.ts --mode full",
    "eval:compare": "tsx scripts/eval/run-promptfoo.ts --mode compare",
    "eval:regression": "tsx scripts/eval/run-promptfoo.ts --mode regression"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.3",
    "@tanstack/react-query": "^5.62.3",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "csv-parser": "^3.2.0",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.4",
    "lancedb": "^0.0.1",
    "lucide-react": "^0.468.0",
    "marked": "^17.0.4",
    "multer": "^2.1.1",
    "next": "15.1.6",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "promptfoo": "^0.121.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.71.2",
    "recharts": "^3.8.0",
    "sonner": "^1.7.0",
    "sql.js": "^1.14.1",
    "systeminformation": "^5.31.4",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1",
    "zustand": "^5.0.2",
    "auth": "^5.0.0-beta.25",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/busboy": "^1.5.4",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/systeminformation": "^3.54.1",
    "@types/uuid": "^11.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@auth/core": "^5.0.0-beta.25",
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.8",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.30.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "15.1.6",
    "jsdom": "^29.0.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "overrides": {
      "react": "^19.0.0",
      "react-dom": "^19.0.0"
    },
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
